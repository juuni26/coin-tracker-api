# Required
JWT_SECRET_KEY=change-me-to-a-long-random-string

# Database — local dev uses async sqlite, production uses async postgres.
# Railway sets DATABASE_URL automatically when you attach a Postgres add-on.
# This app normalizes "postgres://..." → "postgresql+asyncpg://..." at runtime.
DATABASE_URL=sqlite+aiosqlite:///./tracker_coin.db

# Tokens
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=14

# Price providers
COINGECKO_URL=https://api.coingecko.com/api/v3/coins/markets
# Optional — if set, tier-3 uses CoinCap (paid tier) instead of CoinGecko
COINCAP_API_KEY=

# Rate limiting (disable in CI/tests)
RATE_LIMIT_ENABLED=true
